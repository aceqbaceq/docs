запуск
$ export INST_D1=$(mktemp -d -p ~) && echo -e "\e[31mINSTALLATION FOLDER=$INST_D1\e[0m" && cd $INST_D1 && wget -O file.zip "https://github.com/aceqbaceq/docs/raw/refs/heads/master/docker-compose-test/archive.zip" && unzip file.zip && rm file.zip && chmod -R 755 $INST_D1/src && sudo docker compose up -d && sleep 1 && curl http://localhost:80 

